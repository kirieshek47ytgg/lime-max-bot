# ===== Шлюз kapuchino-api (мессенджер MAX) =====
# Самохостинг-шлюз из соседнего проекта kapuchino-api (аналог green-api).
# Запустите его (./run.ps1 + ./run-max.ps1) и привяжите аккаунт MAX по QR.
# Адрес ядра шлюза (по умолчанию слушает только localhost на 8080).
GATEWAY_URL=http://127.0.0.1:8080
# Bearer-токен REST API шлюза — это API_TOKEN из .env проекта kapuchino-api.
GATEWAY_TOKEN=put-your-kapuchino-api-token-here
# Канал отправки: max (можно whatsapp/telegram, если привязаны в kapuchino).
GATEWAY_CHANNEL=max
# Тестовый получатель: если задан, ВСЕ уведомления уходят в один чат
# (для проверки без рассылки гостям). Формат — номер с «+» (+79991234567)
# или готовый числовой chatId MAX. Очистите, чтобы слать гостям по их номеру.
TEST_CHAT_ID=

# ===== Webhook (приём уведомлений от Restoplace) =====
# Путь, который вы пропишете в Restoplace -> Настройки -> Уведомления -> Webhook
WEBHOOK_PATH=/webhook/restoplace
# Необязательный секрет. Если задан, Restoplace должен слать на URL с ?token=...
# (защита от посторонних POST-запросов на ваш эндпоинт)
WEBHOOK_SECRET=

# ===== Логика уведомлений =====
# Типы уведомлений через запятую: created (новая бронь), updated (правка),
# cancelled (отмена). Отмена приходит как reserve.updated со status=6 —
# поэтому фильтруем по смыслу, а не по имени события.
# updated шлётся ТОЛЬКО если изменилось значимое для клиента поле
# (дата/время, беседка, зона, число гостей) — внутренние правки игнорируются.
ENABLED_NOTIFICATIONS=created,updated,cancelled

# Файл-справочник item_id -> название объекта (например "Беседка №2").
ITEMS_FILE=items.json

# Файл со снимками броней (нужен для определения значимых правок).
STATE_FILE=state/reservations.json

# Если true — сообщения НЕ отправляются в шлюз, только пишутся в лог.
# Удобно для локального теста без реальной отправки.
DRY_RUN=true

# Подпись внизу сообщения (например, название базы отдыха и телефон). Может быть пустой.
SIGNATURE=

# ===== Админ-панель (/admin) =====
# Файл базы данных SQLite: клиенты, брони, сообщения, админы панели, журнал сбоёв.
DB_PATH=bot_database.db
# Папка для вложений, которые менеджер шлёт из панели (отдаётся как /media).
MEDIA_DIR=media
# Имя cookie сессии и флаг Secure. Панель через туннель работает по HTTPS —
# можно поставить True (надёжнее). Если открываете панель и по http://localhost —
# оставьте False, иначе браузер не примет cookie по http и вход не сработает.
SESSION_COOKIE=lime_session
COOKIE_SECURE=False
# Логин/пароль ВЛАДЕЛЬЦА панели. Создаётся автоматически при первом старте,
# если в БД ещё нет ни одного администратора. ОБЯЗАТЕЛЬНО смените пароль!
ADMIN_USER=admin
ADMIN_PASSWORD=admin12345

# ===== Прочее =====
HTTP_TIMEOUT=20
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
